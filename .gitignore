# =========================================================
# RPy Extractor - Git Ignore
# Author: Weelson
# Project: C.O.R.E.
# =========================================================

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# IDE/editor metadata
.vscode/
.idea/
*.swp
*.swo

# OS metadata
.DS_Store
Thumbs.db

# Logs and runtime artifacts
*.log
RPy-extractor/logs/

# Extractor-generated working/output directories
RPy-extractor/tmp/
RPy-extractor/assets/
RPy-extractor/.trash*/

# User-local session output (if created outside app folder)
tmp/
assets/
logs/
merged-media/
Test-games/

# Build/distribution artifacts
build/
dist/
*.egg-info/
